<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.fixar.postgres-backup</string>
  <key>ProgramArguments</key><array><string>/opt/fixar-os/scripts/run-postgres-backup.sh</string></array>
  <key>EnvironmentVariables</key><dict><key>FIXAR_BACKUP_ENV_FILE</key><string>/etc/fixar-os/backup.env</string></dict>
  <key>StartCalendarInterval</key><dict><key>Hour</key><integer>2</integer><key>Minute</key><integer>15</integer></dict>
  <key>StandardOutPath</key><string>/var/log/fixar-os/backup-launchd.log</string>
  <key>StandardErrorPath</key><string>/var/log/fixar-os/backup-launchd-error.log</string>
  <key>RunAtLoad</key><true/>
</dict></plist>
